# Flask session signing (required for dashboard login)
FLASK_SECRET_KEY=generate-a-long-random-string

# Dashboard login — create a user in Supabase Auth (Authentication → Users)
# Or set a single admin password when Supabase Auth is not used locally:
# DASHBOARD_PASSWORD=your-secure-password
# DASHBOARD_AUTH_DISABLED=1

# Supabase (required for dashboard live data)
SUPABASE_URL=https://ivhxkseutquczwoxevvu.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required for email/password login page
SUPABASE_ANON_KEY=your-anon-key

# Google Stitch MCP (Cursor reads via STITCH_API_KEY env var)
STITCH_API_KEY=your-stitch-api-key
